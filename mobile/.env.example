# ── Clerk (Authentication) ───────────────────────────────
# Get from https://dashboard.clerk.com → Your App → API Keys
# Must use EXPO_PUBLIC_ prefix for Expo to expose to client
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# ── Convex (Backend) ─────────────────────────────────────
# Same URL as web app — from `npx convex dev` output
EXPO_PUBLIC_CONVEX_URL=https://...convex.cloud
