# ── Clerk (Authentication) ───────────────────────────────
# Get these from https://dashboard.clerk.com → Your App → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk JWT issuer domain for Convex integration
# Format: https://<your-clerk-instance>.clerk.accounts.dev
CLERK_JWT_ISSUER_DOMAIN=https://xxx.clerk.accounts.dev

# Clerk redirect URLs (optional — defaults work for localhost)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# ── Convex (Backend & Database) ──────────────────────────
# Set automatically by `npx convex dev`
CONVEX_DEPLOYMENT=dev:...
NEXT_PUBLIC_CONVEX_URL=https://...convex.cloud

# ── Stripe (Payments) ────────────────────────────────────
# Get these from https://dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe webhook secret — get from Stripe CLI: stripe listen --forward-to localhost:3000/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe price IDs — create in Stripe dashboard
STRIPE_SUBSCRIPTION_PRICE_ID=price_...

# Platform commission percentage (e.g. 10 = 10%)
STRIPE_COMMISSION_PERCENTAGE=10

# ── AI (Sales Page Generation) ───────────────────────────
# Get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Email Notifications ───────────────────────────────────
# Get from https://resend.com → API Keys
# Emails are only sent when this key is present — safe to omit in dev
RESEND_API_KEY=re_...
# Must be a verified domain in Resend (e.g. notifications@masterminding.app)
RESEND_FROM_EMAIL=notifications@masterminding.app

# ── App URL ───────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://www.masterminding.app
